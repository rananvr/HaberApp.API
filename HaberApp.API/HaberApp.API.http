### 3. Haber Ekle
# categoryId kısmına az önce eklediğin kategorinin ID'sini (genelde 1 olur) yaz
POST {{HaberApp.API_HostAddress}}/api/News
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI0IiwiZW1haWwiOiJyYW5hQHRlc3QuY29tIiwicm9sZSI6IlVzZXIiLCJuYmYiOjE3NzYwODA1OTksImV4cCI6MTc3NjY4NTM5OSwiaWF0IjoxNzc2MDgwNTk5LCJpc3MiOiJIYWJlckFwcEFQSSIsImF1ZCI6IkhhYmVyQXBwRmx1dHRlciJ9.o4OhYRqumXuA4w7OzadVJkTSg0r8f8ITOFTq_rN2kRwvc7w7C_bxfRIZsjoEgbssvNlMmJFKWMnJ9h4E1NXwTQ

